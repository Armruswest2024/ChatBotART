# Telegram Bot (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Google Gemini Flash (получить в AI Studio)
GOOGLE_API_KEY=your_google_api_key_here

# Prodamus (регистрация: prodamus.ru)
PRODAMUS_SHOP_ID=your_shop_id
PRODAMUS_SECRET_KEY=your_secret_key
PRODAMUS_URL=https://your-domain.payform.ru/

# Platega (регистрация: platega.io)
PLATEGA_MERCHANT_ID=your_merchant_id
PLATEGA_SECRET_KEY=your_secret_key
PLATEGA_URL=https://app.platega.io

# База данных (по умолчанию SQLite)
DATABASE_URL=sqlite+aiosqlite:///bot.db

# Telegram ID админа (узнать через @userinfobot)
ADMIN_ID=your_telegram_id
